@startuml Iniziativa

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam classFontSize 12
skinparam classBackgroundColor #F8F9FA
skinparam classBorderColor #0052A3
skinparam classHeaderBackgroundColor #0052A3
skinparam classHeaderFontColor #FFFFFF

class Iniziativa {
  + _id : ObjectId
  + titolo : String <<unique, required>>
  + descrizione : String <<required>>
  + stato : String <<enum: in_attesa, approvata, rifiutata>>
  + motivazione_moderazione : String
  + ID_cittadino : ObjectId <<FK Cittadino>>
  + ID_categoria : ObjectId <<FK CategoriaIniziativa>>
  + createdAt : Date
  + updatedAt : Date
}

@enduml
